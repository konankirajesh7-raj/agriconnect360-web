jsx", "source_location": "L87"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "toFixed", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L89"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "toFixed", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L91"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "toFixed", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L93"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L99"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L123"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L129"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L140"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L159"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "slice", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L159"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L185"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L210"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L229"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "(() => {\n        const months = ['Oct','Nov','Dec','Jan','Feb','Mar'];\n        const mIncome  = [102000, 195000, 307000, 88000, 142000, 240000];\n        const mExpense = [51500,  36000,  25000,  42000, 38000,  62000];\n        const mProfit  = mIncome.map((v,i)=>v-mExpense[i]);\n        const maxVal   = Math.max(...mIncome,...mExpense);\n        return (\n          <div>\n            <div style={{ display:'grid', gridTemplateColumns:'repeat(3,1fr)', gap:12, marginBottom:20 }}>\n              {[['\ud83d\udcc8 Total Income',`\u20b9${(totalIncome/1000).toFixed(0)}K`,'#22c55e'],['\ud83d\udcc9 Total Expenses',`\u20b9${(totalExpense/1000).toFixed(0)}K`,'#ef4444'],['\ud83d\udcb9 Net Profit',`\u20b9${(profit/1000).toFixed(0)}K`,profit>=0?'#3b82f6':'#ef4444']].map(([l,v,c])=>(\n                <div key={l} style={{ background:'var(--bg-card)',border:`1px solid ${c}30`,borderRadius:12,padding:'16px 20px',textAlign:'center' }}>\n                  <div style={{ fontSize:'0.75rem',color:'var(--text-muted)',marginBottom:4 }}>{l}</div>\n                  <div style={{ fontSize:'1.6rem',fontWeight:900,color:c }}>{v}</div>\n                  <div style={{ fontSize:'0.68rem',color:'var(--text-muted)',marginTop:2 }}>Margin: {totalIncome?Math.round((profit/totalIncome)*100):0}%</div>\n                </div>\n              ))}\n            </div>\n            <div style={{ display:'grid',gridTemplateColumns:'1fr 1fr',gap:16,marginBottom:20 }}>\n              {/* Income bar chart */}\n              {[['\ud83d\udcca Income Trend',mIncome,'#22c55e'],['\ud83d\udcca Expense Trend',mExpense,'#ef4444']].map(([title,data,color])=>(\n                <div key={title} className=\"card\" style={{ padding:20 }}>\n                  <div style={{ fontWeight:700,marginBottom:16,fontSize:'0.85rem' }}>{title}</div>\n                  <div style={{ display:'flex',alignItems:'flex-end',gap:8,height:120 }}>\n                    {months.map((m,i)=>(\n                      <div key={m} style={{ flex:1,display:'flex',flexDirection:'column',alignItems:'center',gap:4 }}>\n                        <div style={{ fontSize:'0.6rem',color:'var(--text-muted)' }}>\u20b9{(data[i]/1000).toFixed(0)}k</div>\n                        <div style={{ width:'100%',background:color,borderRadius:'4px 4px 0 0',height:`${(data[i]/maxVal)*90}px`,opacity:0.85 }} />\n                        <div style={{ fontSize:'0.62rem',color:'var(--text-muted)' }}>{m}</div>\n                      </div>\n                    ))}\n                  </div>\n                </div>\n              ))}\n            </div>\n            <div className=\"card\" style={{ padding:20 }}>\n              <div style={{ fontWeight:700,marginBottom:14,fontSize:'0.85rem' }}>\ud83d\udccb Monthly Breakdown</div>\n              <table className=\"data-table\"><thead><tr><th>MONTH</th><th>INCOME</th><th>EXPENSE</th><th>PROFIT</th><th>MARGIN</th></tr></thead>\n                <tbody>{months.map((m,i)=>(\n                  <tr key={m}>\n                    <td style={{ fontWeight:700 }}>{m}</td>\n                    <td style={{ color:'#22c55e',fontWeight:700 }}>\u20b9{mIncome[i].toLocaleString()}</td>\n                    <td style={{ color:'#ef4444',fontWeight:700 }}>\u20b9{mExpense[i].toLocaleString()}</td>\n                    <td style={{ color:mProfit[i]>=0?'#3b82f6':'#ef4444',fontWeight:800 }}>\u20b9{mProfit[i].toLocaleString()}</td>\n                    <td><span style={{ background:mProfit[i]>=0?'rgba(34,197,94,0.1)':'rgba(239,68,68,0.1)',color:mProfit[i]>=0?'#22c55e':'#ef4444',padding:'2px 10px',borderRadius:20,fontSize:'0.75rem',fontWeight:700 }}>{((mProfit[i]/mIncome[i])*100).toFixed(1)}%</span></td>\n                  </tr>\n                ))}</tbody>\n              </table>\n              <button style={{ marginTop:16,padding:'10px 20px',borderRadius:10,border:'none',background:'linear-gradient(135deg,#22c55e,#16a34a)',color:'#fff',fontWeight:700,cursor:'pointer',fontSize:'0.85rem' }}\n                onClick={()=>window.print()}>\ud83d\udce5 Download Report</button>\n            </div>\n          </div>\n        );\n      })", "is_member_call": false, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L251"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L312"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L318"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "parseFloat", "is_member_call": false, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L320"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "parseFloat", "is_member_call": false, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L320"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "toLocaleString", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L323"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "parseFloat", "is_member_call": false, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L323"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "parseFloat", "is_member_call": false, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L323"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L340"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "keys", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L340"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L341"}, {"caller_nid": "pages_mymoneypage_mymoneypage", "callee": "map", "is_member_call": true, "source_file": "E:\\OneDrive\\Desktop\\AGRI_360\\AGRI_360_PROGRAMS\\AgriConnect360Web\\src\\pages\\MyMoneyPage.jsx", "source_location": "L345"}]}