# ─── AgriConnect360 Environment Variables ─────────────────────────────────────
# Copy this to .env and fill in your values
# NEVER commit the actual .env file!

# ─── Supabase (Database + Auth + Realtime) ──────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── AI Services ─────────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_GROQ_API_KEY=your_groq_api_key

# ─── Weather API ─────────────────────────────────────────────────────────────
VITE_OPENWEATHER_API_KEY=your_openweather_key

# ─── Default Location (Andhra Pradesh — Guntur) ──────────────────────────────
VITE_DEFAULT_STATE=Andhra Pradesh
VITE_DEFAULT_DISTRICT=Guntur
VITE_DEFAULT_LAT=16.3067
VITE_DEFAULT_LON=80.4365

# ─── App Config ──────────────────────────────────────────────────────────────
VITE_APP_NAME=AgriConnect 360
VITE_APP_VERSION=1.0.0
